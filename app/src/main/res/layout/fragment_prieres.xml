<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="80dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="12dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#33FFFFFF"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/tvDateHijri"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aujourd'hui, Vendredi 7 Mars 2026"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:fontFamily="@font/poppins_medium"/>

            <TextView
                android:id="@+id/tvHijriSub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ramadan · 7ème jour"
                android:textColor="#7FA68A"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_light"
                android:layout_marginTop="2dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#33FFFFFF"
                android:layout_marginTop="12dp"/>

        </LinearLayout>

        <!-- NEXT PRAYER BANNER -->
        <LinearLayout
            android:id="@+id/nextPrayerBanner"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:background="@drawable/bg_next_prayer"
            android:elevation="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Prochaine\nprière"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:fontFamily="@font/poppins_bold"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/tvNextPrayerName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Isha"
                    android:textColor="#7FA68A"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_regular"/>

                <TextView
                    android:id="@+id/tvNextPrayerCountdown"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="dans 1h 26min"
                    android:textColor="#2ECC71"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_regular"/>

            </LinearLayout>

        </LinearLayout>

        <!-- PRAYER TIMES CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:orientation="vertical"
            android:background="@drawable/bg_prayer_card"
            android:paddingVertical="4dp">

            <!-- Fajr -->
            <LinearLayout
                android:id="@+id/rowFajr"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_prayer_row">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Fajr"
                    android:textColor="#7FA68A"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_medium"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌅"
                    android:textSize="15sp"
                    android:layout_marginEnd="12dp"/>

                <View
                    android:layout_width="1dp"
                    android:layout_height="20dp"
                    android:background="#33FFFFFF"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:id="@+id/tvFajr"
                    android:layout_width="50dp"
                    android:layout_height="wrap_content"
                    android:text="05:23"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_regular"
                    android:gravity="end"/>

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#1AFFFFFF" android:layout_marginHorizontal="16dp"/>

            <!-- Sunrise -->
            <LinearLayout
                android:id="@+id/rowSunrise"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_prayer_row">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Lever du soleil"
                    android:textColor="#7FA68A"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_regular"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌄"
                    android:textSize="15sp"
                    android:layout_marginEnd="12dp"/>

                <View
                    android:layout_width="1dp"
                    android:layout_height="20dp"
                    android:background="#33FFFFFF"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:id="@+id/tvSunrise"
                    android:layout_width="50dp"
                    android:layout_height="wrap_content"
                    android:text="06:45"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_regular"
                    android:gravity="end"/>

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#1AFFFFFF" android:layout_marginHorizontal="16dp"/>

            <!-- Dhuhr -->
            <LinearLayout
                android:id="@+id/rowDhuhr"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_prayer_row">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Dhuhr"
                    android:textColor="#7FA68A"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_regular"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="☀️"
                    android:textSize="15sp"
                    android:layout_marginEnd="12dp"/>

                <View
                    android:layout_width="1dp"
                    android:layout_height="20dp"
                    android:background="#33FFFFFF"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:id="@+id/tvDhuhr"
                    android:layout_width="50dp"
                    android:layout_height="wrap_content"
                    android:text="13:15"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_regular"
                    android:gravity="end"/>

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#1AFFFFFF" android:layout_marginHorizontal="16dp"/>

            <!-- Asr -->
            <LinearLayout
                android:id="@+id/rowAsr"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_prayer_row">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Asr"
                    android:textColor="#7FA68A"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_regular"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌤️"
                    android:textSize="15sp"
                    android:layout_marginEnd="12dp"/>

                <View
                    android:layout_width="1dp"
                    android:layout_height="20dp"
                    android:background="#33FFFFFF"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:id="@+id/tvAsr"
                    android:layout_width="50dp"
                    android:layout_height="wrap_content"
                    android:text="16:45"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_regular"
                    android:gravity="end"/>

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#1AFFFFFF" android:layout_marginHorizontal="16dp"/>

            <!-- Maghrib - ACTIVE -->
            <LinearLayout
                android:id="@+id/rowMaghrib"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_prayer_row_active"
                android:elevation="2dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Maghrib"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_semibold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌇"
                    android:textSize="15sp"
                    android:layout_marginEnd="12dp"/>

                <View
                    android:layout_width="1dp"
                    android:layout_height="20dp"
                    android:background="#33FFFFFF"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:id="@+id/tvMaghrib"
                    android:layout_width="50dp"
                    android:layout_height="wrap_content"
                    android:text="19:12"
                    android:textColor="#2ECC71"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_semibold"
                    android:gravity="end"/>

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#1AFFFFFF" android:layout_marginHorizontal="16dp"/>

            <!-- Isha -->
            <LinearLayout
                android:id="@+id/rowIsha"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_prayer_row">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Isha"
                    android:textColor="#7FA68A"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_regular"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌙"
                    android:textSize="15sp"
                    android:layout_marginEnd="12dp"/>

                <View
                    android:layout_width="1dp"
                    android:layout_height="20dp"
                    android:background="#33FFFFFF"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:id="@+id/tvIsha"
                    android:layout_width="50dp"
                    android:layout_height="wrap_content"
                    android:text="20:38"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_regular"
                    android:gravity="end"/>

            </LinearLayout>

        </LinearLayout>

        <!-- QIBLA CARD -->
        <LinearLayout
            android:id="@+id/qiblaCard"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:background="@drawable/bg_surface"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/ripple_green_rounded">

            <TextView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="🕌"
                android:textSize="28sp"
                android:gravity="center"
                android:layout_marginEnd="12dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Direction Qibla"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_semibold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vers La Mecque"
                    android:textColor="#7FA68A"
                    android:textSize="11sp"
                    android:fontFamily="@font/poppins_regular"/>

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="›"
                android:textColor="#7FA68A"
                android:textSize="24sp"/>

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>