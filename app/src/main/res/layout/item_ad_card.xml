<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:orientation="vertical"
    android:background="@drawable/bg_ad_card"
    android:clickable="true"
    android:focusable="true"
    android:foreground="@drawable/ripple_green"
    android:elevation="2dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:background="#1E3D2A">

        <!-- Real image from Cloudinary -->
        <ImageView
            android:id="@+id/ivAdImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:contentDescription="@string/app_name"/>

        <!-- Fallback emoji when no image -->
        <TextView
            android:id="@+id/tvAdEmoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:textSize="40sp"/>

        <ImageView
            android:id="@+id/ivBookmark"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="top|end"
            android:layout_margin="6dp"
            android:src="@drawable/ic_bookmark_outline"
            android:contentDescription="@string/save_ad"
            android:clickable="true"
            android:focusable="true"
            android:padding="2dp"/>
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp">

        <TextView
            android:id="@+id/tvAdTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_semibold"
            android:maxLines="2"/>

        <TextView
            android:id="@+id/tvAdLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#7FA68A"
            android:textSize="10sp"
            android:fontFamily="@font/poppins_regular"
            android:layout_marginTop="3dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <TextView
                android:id="@+id/tvAdPrice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#2ECC71"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_bold"/>

            <TextView
                android:id="@+id/tvAdTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#7FA68A"
                android:textSize="9sp"
                android:fontFamily="@font/poppins_regular"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>