<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <View
        android:id="@+id/statusBarSpacer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="#132D1F"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="#132D1F">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_back"
            android:contentDescription="@string/back"
            android:padding="4dp"
            android:clickable="true"
            android:focusable="true"
            app:tint="#FFFFFF"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/qibla_title"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:fontFamily="@font/poppins_bold"
            android:gravity="center"/>

        <View
            android:layout_width="32dp"
            android:layout_height="32dp"/>
    </LinearLayout>

    <!-- Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingBottom="32dp">

            <!-- GPS Status Card -->
            <LinearLayout
                android:id="@+id/gpsStatusCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp"
                android:background="@drawable/bg_surface">

                <View
                    android:id="@+id/gpsIndicator"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_gps_dot_active"
                    android:layout_marginEnd="10dp"/>

                <TextView
                    android:id="@+id/tvGpsStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/qibla_loading"
                    android:textColor="#7FA68A"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_regular"/>

                <TextView
                    android:id="@+id/tvCoords"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#557FA68A"
                    android:textSize="10sp"
                    android:fontFamily="@font/poppins_light"/>
            </LinearLayout>

            <!-- Compass -->
            <com.madinatti.app.QiblaCompassView
                android:id="@+id/qiblaCompass"
                android:layout_width="300dp"
                android:layout_height="300dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="24dp"/>

            <!-- Bearing -->
            <TextView
                android:id="@+id/tvQiblaBearing"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:textColor="#2ECC71"
                android:textSize="22sp"
                android:fontFamily="@font/poppins_bold"
                android:layout_marginTop="20dp"/>

            <!-- Direction label -->
            <TextView
                android:id="@+id/tvQiblaDirection"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:fontFamily="@font/poppins_semibold"
                android:layout_marginTop="4dp"/>

            <!-- Distance -->
            <TextView
                android:id="@+id/tvQiblaDistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:textColor="#7FA68A"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_regular"
                android:layout_marginTop="4dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1AFFFFFF"
                android:layout_marginHorizontal="40dp"
                android:layout_marginVertical="20dp"/>

            <TextView
                android:id="@+id/tvAccuracy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="@string/qibla_compass_active"
                android:textColor="#2ECC71"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="@string/qibla_tip"
                android:textColor="#557FA68A"
                android:textSize="11sp"
                android:fontFamily="@font/poppins_light"
                android:gravity="center"
                android:layout_marginTop="12dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>