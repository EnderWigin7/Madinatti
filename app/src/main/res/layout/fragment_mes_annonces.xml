<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- TOP BAR -->
    <LinearLayout
        android:id="@+id/mesAnnoncesTopBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#132D1F">

        <View
            android:id="@+id/statusBarSpacer"
            android:layout_width="match_parent"
            android:layout_height="0dp"/>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingHorizontal="16dp">

            <TextView
                android:id="@+id/ivBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="←"
                android:textColor="#2ECC71"
                android:textSize="22sp"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mes annonces"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:fontFamily="@font/poppins_semibold"
                android:layout_centerInParent="true"/>

            <TextView
                android:id="@+id/tvNewAd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+ Nouvelle"
                android:textColor="#7FA68A"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_medium"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true"
                android:clickable="true"
                android:focusable="true"/>

        </RelativeLayout>
    </LinearLayout>

    <!-- SCROLLABLE CONTENT -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- STATS ROW -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <!-- Total -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="74dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_stat_card">

                    <TextView
                        android:id="@+id/tvStatTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12"
                        android:textColor="#2ECC71"
                        android:textSize="20sp"
                        android:fontFamily="@font/poppins_bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total"
                        android:textColor="#7FA68A"
                        android:textSize="10sp"
                        android:fontFamily="@font/poppins_regular"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="74dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="4dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_stat_card">

                    <TextView
                        android:id="@+id/tvStatActives"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="8"
                        android:textColor="#2ECC71"
                        android:textSize="20sp"
                        android:fontFamily="@font/poppins_bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Actives"
                        android:textColor="#7FA68A"
                        android:textSize="10sp"
                        android:fontFamily="@font/poppins_regular"/>
                </LinearLayout>

                <!-- Vendues -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="74dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="4dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_stat_card">

                    <TextView
                        android:id="@+id/tvStatVendues"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3"
                        android:textColor="#2ECC71"
                        android:textSize="20sp"
                        android:fontFamily="@font/poppins_bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Vendues"
                        android:textColor="#7FA68A"
                        android:textSize="10sp"
                        android:fontFamily="@font/poppins_regular"/>
                </LinearLayout>

                <!-- Expirées -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="74dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_stat_card">

                    <TextView
                        android:id="@+id/tvStatExpirees"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1"
                        android:textColor="#2ECC71"
                        android:textSize="20sp"
                        android:fontFamily="@font/poppins_bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Expirées"
                        android:textColor="#7FA68A"
                        android:textSize="10sp"
                        android:fontFamily="@font/poppins_regular"/>
                </LinearLayout>

            </LinearLayout>

            <!-- FILTER CHIPS -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingHorizontal="16dp"
                android:paddingBottom="14dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/chipToutes"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:paddingHorizontal="16dp"
                        android:gravity="center"
                        android:text="Toutes"
                        android:textSize="11sp"
                        android:fontFamily="@font/poppins_medium"
                        android:textColor="#0D1F17"
                        android:background="@drawable/bg_chip_selected"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/chipActives"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:paddingHorizontal="16dp"
                        android:gravity="center"
                        android:text="Actives"
                        android:textSize="11sp"
                        android:fontFamily="@font/poppins_medium"
                        android:textColor="#7FA68A"
                        android:background="@drawable/bg_chip"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/chipVendues"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:paddingHorizontal="16dp"
                        android:gravity="center"
                        android:text="Vendues"
                        android:textSize="11sp"
                        android:fontFamily="@font/poppins_medium"
                        android:textColor="#7FA68A"
                        android:background="@drawable/bg_chip"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/chipExpirees"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:paddingHorizontal="16dp"
                        android:gravity="center"
                        android:text="Expirées"
                        android:textSize="11sp"
                        android:fontFamily="@font/poppins_medium"
                        android:textColor="#7FA68A"
                        android:background="@drawable/bg_chip"
                        android:clickable="true"
                        android:focusable="true"/>

                </LinearLayout>
            </HorizontalScrollView>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMyAds"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false"
                android:paddingHorizontal="16dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>