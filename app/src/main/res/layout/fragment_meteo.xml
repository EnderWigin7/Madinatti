<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- ✅ NO gradient background views here -->

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="18dp"
            android:paddingTop="12dp"
            android:paddingBottom="16dp">

            <!-- ✅ Main Temp Card - gets gradient applied by code -->
            <LinearLayout
                android:id="@+id/mainTempCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_weather_glass"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp">

                <TextView
                    android:id="@+id/tvWeatherEmoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/weather_emoji_default"
                    android:textSize="56sp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="end"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:id="@+id/tvTemperature"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/weather_temp_default"
                        android:textColor="#FFFFFF"
                        android:textSize="48sp"
                        android:fontFamily="@font/poppins_bold"
                        android:includeFontPadding="false"/>

                    <TextView
                        android:id="@+id/tvCondition"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/weather_condition_default"
                        android:textColor="#EEFFFFFF"
                        android:textSize="14sp"
                        android:fontFamily="@font/poppins_light"/>

                    <TextView
                        android:id="@+id/tvFeelsLike"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/weather_feels_default"
                        android:textColor="#AAFFFFFF"
                        android:textSize="11sp"
                        android:fontFamily="@font/poppins_regular"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ✅ 4-Stat Grid - each gets gradient applied by code -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <!-- ✅ Add android:id to each stat box -->
                <LinearLayout
                    android:id="@+id/statHumidity"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="3dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_weather_stat"
                    android:paddingVertical="8dp">
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/emoji_droplet" android:textSize="16sp"/>
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/weather_humidity"
                        android:textColor="#BBFFFFFF" android:textSize="9sp"
                        android:fontFamily="@font/poppins_regular"/>
                    <TextView android:id="@+id/tvHumidity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/weather_humidity_default"
                        android:textColor="#FFFFFF" android:textSize="14sp"
                        android:fontFamily="@font/poppins_bold"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/statWind"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="3dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_weather_stat"
                    android:paddingVertical="8dp">
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/emoji_wind_face" android:textSize="16sp"/>
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/weather_wind"
                        android:textColor="#BBFFFFFF" android:textSize="9sp"
                        android:fontFamily="@font/poppins_regular"/>
                    <TextView android:id="@+id/tvWind"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/weather_wind_default"
                        android:textColor="#FFFFFF" android:textSize="14sp"
                        android:fontFamily="@font/poppins_bold"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/statSunrise"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="3dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_weather_stat"
                    android:paddingVertical="8dp">
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/emoji_sunrise" android:textSize="16sp"/>
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/weather_sunrise"
                        android:textColor="#BBFFFFFF" android:textSize="9sp"
                        android:fontFamily="@font/poppins_regular"/>
                    <TextView android:id="@+id/tvSunrise"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/weather_sunrise_time"
                        android:textColor="#FFFFFF" android:textSize="11sp"
                        android:fontFamily="@font/poppins_semibold"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/statSunset"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="3dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_weather_stat"
                    android:paddingVertical="8dp">
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/emoji_sunset" android:textSize="16sp"/>
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/weather_sunset"
                        android:textColor="#BBFFFFFF" android:textSize="9sp"
                        android:fontFamily="@font/poppins_regular"/>
                    <TextView android:id="@+id/tvSunset"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/weather_sunset_time"
                        android:textColor="#FFFFFF" android:textSize="11sp"
                        android:fontFamily="@font/poppins_semibold"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Today label -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="6dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/weather_today"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_bold"/>
                <TextView
                    android:id="@+id/tvTodayDesc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/weather_today_desc"
                    android:textColor="#77FFFFFF"
                    android:textSize="8sp"
                    android:fontFamily="@font/poppins_light"/>
            </LinearLayout>

            <!-- Hourly scroll -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:clipToPadding="false">
                <LinearLayout
                    android:id="@+id/hourlyRow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"/>
            </HorizontalScrollView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/weather_forecast_7day"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:fontFamily="@font/poppins_bold"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="6dp"/>

            <LinearLayout
                android:id="@+id/forecastList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_weather_glass"
                android:paddingVertical="2dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</FrameLayout>