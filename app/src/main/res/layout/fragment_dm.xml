<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- TOP BAR — sticky -->
    <LinearLayout
        android:id="@+id/dmTopBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#132D1F">

        <View
            android:id="@+id/statusBarSpacer"
            android:layout_width="match_parent"
            android:layout_height="0dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:paddingHorizontal="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Back arrow -->
            <ImageView
                android:id="@+id/ivDmBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_back"
                android:contentDescription="@string/app_name"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                app:tint="#2ECC71"/>

            <TextView
                android:id="@+id/tvDmAvatar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="@sA"
                android:textColor="#0D1F17"
                android:textSize="18sp"
                android:fontFamily="@font/poppins_bold"
                android:gravity="center"
                android:background="@drawable/bg_unread_badge"
                android:layout_marginEnd="10dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvDmName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Aicha's"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:fontFamily="@font/poppins_semibold"/>

                <TextView
                    android:id="@+id/tvDmStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="En ligne"
                    android:textColor="#2ECC71"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_regular"/>

            </LinearLayout>

            <!-- Call icon (placeholder) -->
            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_bell"
                android:contentDescription="@string/app_name"
                android:padding="6dp"
                android:clickable="true"
                android:focusable="true"
                app:tint="#FFFFFF"/>

        </LinearLayout>
    </LinearLayout>

    <!-- MESSAGES LIST -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:clipToPadding="false"
        android:scrollbars="none"/>

    <!-- INPUT BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:background="#132D1F">

        <!-- Attachment icon -->
        <TextView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="📎"
            android:textSize="20sp"
            android:gravity="center"
            android:layout_marginEnd="8dp"/>

        <!-- Input field -->
        <EditText
            android:id="@+id/etMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Écrire un message..."
            android:textColor="#FFFFFF"
            android:textColorHint="#7FA68A"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_regular"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp"
            android:background="@drawable/bg_dm_input"
            android:inputType="textMultiLine"
            android:maxLines="4"
            android:minLines="1"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/btnSend"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:text="➤"
            android:textColor="#0D1F17"
            android:textSize="18sp"
            android:gravity="center"
            android:background="@drawable/bg_unread_badge"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

</LinearLayout>