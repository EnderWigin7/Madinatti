<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <LinearLayout
        android:id="@+id/editProfileTopBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#132D1F">

        <View
            android:id="@+id/statusBarSpacer"
            android:layout_width="match_parent"
            android:layout_height="0dp"/>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingLeft="16dp"
            android:paddingRight="16dp">

            <ImageView
                android:id="@+id/ivEditBack"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_back"
                android:contentDescription="@string/back"
                android:padding="4dp"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"
                android:clickable="true"
                android:focusable="true"
                app:tint="#FFFFFF"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/modifier_profil"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:fontFamily="@font/poppins_semibold"
                android:layout_centerInParent="true"/>

            <TextView
                android:id="@+id/tvSave"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/enregistrer"
                android:textColor="#2ECC71"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_medium"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true"
                android:clickable="true"
                android:focusable="true"/>

        </RelativeLayout>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <!-- AVATAR SECTION -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingTop="24dp"
                android:paddingBottom="16dp">

                <FrameLayout
                    android:layout_width="90dp"
                    android:layout_height="90dp">

                    <ImageView
                        android:id="@+id/ivEditAvatar"
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:scaleType="centerCrop"
                        android:background="@drawable/bg_avatar_edit"
                        android:visibility="gone"
                        android:contentDescription="@string/avatar"/>

                    <TextView
                        android:id="@+id/tvAvatarFallback"
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:text="@string/icon_person"
                        android:textSize="40sp"
                        android:gravity="center"
                        android:background="@drawable/bg_avatar_edit"
                        android:visibility="visible"/>

                    <TextView
                        android:id="@+id/btnChangePhoto"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="bottom|end"
                        android:text="@string/icon_edit"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:background="@drawable/bg_btn_green"
                        android:clickable="true"
                        android:focusable="true"/>

                </FrameLayout>

                <TextView
                    android:id="@+id/tvChangePhotoLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/change_photo"
                    android:textColor="#2ECC71"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_regular"
                    android:layout_marginTop="8dp"
                    android:clickable="true"
                    android:focusable="true"/>

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1E3D2A"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/personal_info"
                android:textColor="#7FA68A"
                android:textSize="11sp"
                android:fontFamily="@font/poppins_medium"
                android:letterSpacing="0.05"
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"/>

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/nom_complet" android:textColor="#7FA68A" android:textSize="11sp"
                android:fontFamily="@font/poppins_regular"
                android:paddingHorizontal="16dp" android:paddingBottom="4dp"/>

            <EditText
                android:id="@+id/etNomComplet"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginHorizontal="16dp"
                android:hint="Votre nom"
                android:textColor="#FFFFFF"
                android:textColorHint="#4DFFFFFF"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_regular"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_input"
                android:singleLine="true"
                android:layout_marginBottom="12dp"/>

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Email" android:textColor="#7FA68A" android:textSize="11sp"
                android:fontFamily="@font/poppins_regular"
                android:paddingHorizontal="16dp" android:paddingBottom="4dp"/>

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginHorizontal="16dp"
                android:hint="example@gmail.com"
                android:textColor="#FFFFFF"
                android:textColorHint="#4DFFFFFF"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_regular"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_input"
                android:inputType="textEmailAddress"
                android:singleLine="true"
                android:enabled="false"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚠️ L'email ne peut pas être modifié ici"
                android:textColor="#7FA68A"
                android:textSize="10sp"
                android:fontFamily="@font/poppins_regular"
                android:paddingHorizontal="16dp"
                android:paddingTop="4dp"
                android:paddingBottom="12dp"/>

            <!-- Téléphone -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Téléphone" android:textColor="#7FA68A" android:textSize="11sp"
                android:fontFamily="@font/poppins_regular"
                android:paddingHorizontal="16dp" android:paddingBottom="4dp"/>

            <EditText
                android:id="@+id/etTelephone"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginHorizontal="16dp"
                android:hint="0677991788"
                android:textColor="#FFFFFF"
                android:textColorHint="#4DFFFFFF"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_regular"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_input"
                android:inputType="phone"
                android:singleLine="true"
                android:layout_marginBottom="12dp"/>

            <!-- Âge -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Âge" android:textColor="#7FA68A" android:textSize="11sp"
                android:fontFamily="@font/poppins_regular"
                android:paddingHorizontal="16dp" android:paddingBottom="4dp"/>

            <EditText
                android:id="@+id/etAge"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginHorizontal="16dp"
                android:hint="Votre âge"
                android:textColor="#FFFFFF"
                android:textColorHint="#4DFFFFFF"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_regular"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_input"
                android:inputType="number"
                android:singleLine="true"
                android:maxLength="3"
                android:layout_marginBottom="12dp"/>

            <!-- Ville -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Ville" android:textColor="#7FA68A" android:textSize="11sp"
                android:fontFamily="@font/poppins_regular"
                android:paddingHorizontal="16dp" android:paddingBottom="4dp"/>

            <LinearLayout
                android:id="@+id/cityPicker"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginHorizontal="16dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_input"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Choisir votre ville"
                    android:textColor="#4DFFFFFF"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_regular"/>

                <TextView
                    android:id="@+id/tvSelectedCity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_regular"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▾"
                    android:textColor="#7FA68A"
                    android:textSize="16sp"/>

            </LinearLayout>

            <!-- Bio -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Bio" android:textColor="#7FA68A" android:textSize="11sp"
                android:fontFamily="@font/poppins_regular"
                android:paddingHorizontal="16dp" android:paddingBottom="4dp"/>

            <EditText
                android:id="@+id/etBio"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginHorizontal="16dp"
                android:hint="Parlez de vous..."
                android:textColor="#FFFFFF"
                android:textColorHint="#4DFFFFFF"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_regular"
                android:paddingHorizontal="16dp"
                android:paddingTop="12dp"
                android:background="@drawable/bg_input"
                android:inputType="textMultiLine"
                android:gravity="top"
                android:maxLines="4"
                android:layout_marginBottom="12dp"/>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#1E3D2A" android:layout_marginTop="8dp"/>

            <!-- SÉCURITÉ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SÉCURITÉ"
                android:textColor="#7FA68A"
                android:textSize="11sp"
                android:fontFamily="@font/poppins_medium"
                android:letterSpacing="0.05"
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"/>

            <!-- Current password -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Mot de passe actuel" android:textColor="#7FA68A" android:textSize="11sp"
                android:fontFamily="@font/poppins_regular"
                android:paddingHorizontal="16dp" android:paddingBottom="4dp"/>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="12dp">

                <EditText
                    android:id="@+id/etCurrentPassword"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="••••••••"
                    android:textColorHint="#7FA68A"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:paddingHorizontal="16dp"
                    android:paddingEnd="44dp"
                    android:background="@drawable/bg_input"
                    android:inputType="textPassword"
                    android:singleLine="true"/>

                <ImageView
                    android:id="@+id/ivToggleCurrentPw"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center_vertical|end"
                    android:layout_marginEnd="8dp"
                    android:padding="6dp"
                    android:src="@drawable/ic_eye_closed"
                    android:contentDescription="toggle"
                    app:tint="#7FA68A"/>
            </FrameLayout>

            <!-- New password -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Nouveau mot de passe" android:textColor="#7FA68A" android:textSize="11sp"
                android:fontFamily="@font/poppins_regular"
                android:paddingHorizontal="16dp" android:paddingBottom="4dp"/>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="12dp">

                <EditText
                    android:id="@+id/etNewPassword"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="••••••••"
                    android:textColorHint="#7FA68A"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:paddingHorizontal="16dp"
                    android:paddingEnd="44dp"
                    android:background="@drawable/bg_input"
                    android:inputType="textPassword"
                    android:singleLine="true"/>

                <ImageView
                    android:id="@+id/ivToggleNewPw"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center_vertical|end"
                    android:layout_marginEnd="8dp"
                    android:padding="6dp"
                    android:src="@drawable/ic_eye_closed"
                    android:contentDescription="toggle"
                    app:tint="#7FA68A"/>
            </FrameLayout>

            <!-- Confirm password -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Confirmer mot de passe" android:textColor="#7FA68A" android:textSize="11sp"
                android:fontFamily="@font/poppins_regular"
                android:paddingHorizontal="16dp" android:paddingBottom="4dp"/>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="16dp">

                <EditText
                    android:id="@+id/etConfirmPassword"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="••••••••"
                    android:textColorHint="#7FA68A"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:paddingHorizontal="16dp"
                    android:paddingEnd="44dp"
                    android:background="@drawable/bg_input"
                    android:inputType="textPassword"
                    android:singleLine="true"/>

                <ImageView
                    android:id="@+id/ivToggleConfirmPw"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center_vertical|end"
                    android:layout_marginEnd="8dp"
                    android:padding="6dp"
                    android:src="@drawable/ic_eye_closed"
                    android:contentDescription="toggle"
                    app:tint="#7FA68A"/>
            </FrameLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#1E3D2A"/>

            <!-- Delete account -->
            <LinearLayout
                android:id="@+id/btnDeleteAccount"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:background="@drawable/bg_btn_delete"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🗑️ Supprimer mon compte"
                    android:textColor="#E74C3C"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_medium"/>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>