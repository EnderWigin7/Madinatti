<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B1913">

    <com.madinatti.app.ParticleView
        android:id="@+id/particleView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Logo -->
        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="140dp"
            android:layout_height="95dp"
            android:src="@drawable/madinatilogopdf"
            android:contentDescription="@string/app_name"
            android:layout_marginTop="56dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Segmented Toggle -->
        <FrameLayout
            android:id="@+id/segmentedToggle"
            android:layout_width="214dp"
            android:layout_height="37dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_segment_container"
            app:layout_constraintTop_toBottomOf="@id/imgLogo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <View
                android:id="@+id/segmentIndicator"
                android:layout_width="107dp"
                android:layout_height="match_parent"
                android:background="@drawable/bg_segment_left"/>

            <TextView
                android:id="@+id/tvSegmentLogin"
                android:layout_width="107dp"
                android:layout_height="match_parent"
                android:text="Connexion"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_semibold"
                android:gravity="center"
                android:layout_gravity="start"/>

            <TextView
                android:id="@+id/tvSegmentRegister"
                android:layout_width="107dp"
                android:layout_height="match_parent"
                android:text="S'inscrire"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_semibold"
                android:gravity="center"
                android:layout_gravity="end"/>

        </FrameLayout>

        <!-- Fragment Container -->
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/fragmentContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/segmentedToggle"
            app:layout_constraintBottom_toTopOf="@id/dividerOu"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- "ou" divider -->
        <RelativeLayout
            android:id="@+id/dividerOu"
            android:layout_width="match_parent"
            android:layout_height="37dp"
            android:paddingHorizontal="24dp"
            android:layout_marginBottom="8dp"
            app:layout_constraintBottom_toTopOf="@id/btnSocial"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <View
                android:layout_width="120dp"
                android:layout_height="1dp"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"
                android:background="#FFFFFF"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ou"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:fontFamily="@font/poppins_bold"
                android:layout_centerInParent="true"/>

            <View
                android:layout_width="120dp"
                android:layout_height="1dp"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true"
                android:background="#FFFFFF"/>

        </RelativeLayout>

        <!-- Social button -->
        <FrameLayout
            android:id="@+id/btnSocial"
            android:layout_width="250dp"
            android:layout_height="32dp"
            android:layout_marginBottom="36dp"
            android:background="@drawable/bg_surface"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="12dp"
                android:src="@android:drawable/ic_menu_share"
                android:contentDescription="@string/app_name"
                app:tint="#FFFFFF"/>

            <TextView
                android:id="@+id/tvSocialLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="40dp"
                android:fontFamily="@font/poppins_medium"
                android:text="Connexion via réseau social"
                android:textColor="#FFFFFF"
                android:textSize="10sp"/>

        </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>