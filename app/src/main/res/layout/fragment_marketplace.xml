<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/transparent">

    <LinearLayout
        android:id="@+id/marketSearchBar"
        android:layout_width="match_parent"
        android:layout_height="37dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="6dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:background="@drawable/bg_search"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/search_annonces"
            android:textColor="#7FA68A"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_regular"/>

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_search"
            android:contentDescription="@string/app_name"
            app:tint="#7FA68A"/>
    </LinearLayout>

    <!-- Category chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:scrollbars="none"
        android:paddingHorizontal="10dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout android:id="@+id/catTout" android:layout_width="wrap_content" android:layout_height="30dp" android:gravity="center" android:paddingHorizontal="12dp" android:layout_marginEnd="5dp" android:background="@drawable/bg_chip_selected" android:clickable="true" android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/cat_tout" android:textColor="#0D1F17" android:textSize="11sp" android:fontFamily="@font/poppins_medium"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/catMaison" android:layout_width="wrap_content" android:layout_height="30dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="10dp" android:layout_marginEnd="5dp" android:background="@drawable/bg_chip" android:clickable="true" android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/emoji_sofa" android:textSize="13sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/cat_maison" android:textColor="#7FA68A" android:textSize="11sp" android:fontFamily="@font/poppins_regular"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/catElectronique" android:layout_width="wrap_content" android:layout_height="30dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="10dp" android:layout_marginEnd="5dp" android:background="@drawable/bg_chip" android:clickable="true" android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/emoji_phone" android:textSize="13sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/cat_electronique" android:textColor="#7FA68A" android:textSize="11sp" android:fontFamily="@font/poppins_regular"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/catVoitures" android:layout_width="wrap_content" android:layout_height="30dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="10dp" android:layout_marginEnd="5dp" android:background="@drawable/bg_chip" android:clickable="true" android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/emoji_car" android:textSize="13sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/cat_voitures" android:textColor="#7FA68A" android:textSize="11sp" android:fontFamily="@font/poppins_regular"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/catVetements" android:layout_width="wrap_content" android:layout_height="30dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="10dp" android:layout_marginEnd="5dp" android:background="@drawable/bg_chip" android:clickable="true" android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/emoji_dress" android:textSize="13sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/cat_vetements" android:textColor="#7FA68A" android:textSize="11sp" android:fontFamily="@font/poppins_regular"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/catImmobilier" android:layout_width="wrap_content" android:layout_height="30dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="10dp" android:layout_marginEnd="5dp" android:background="@drawable/bg_chip" android:clickable="true" android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/emoji_house" android:textSize="13sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/cat_immobilier" android:textColor="#7FA68A" android:textSize="11sp" android:fontFamily="@font/poppins_regular"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/catArtisanat" android:layout_width="wrap_content" android:layout_height="30dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="10dp" android:background="@drawable/bg_chip" android:clickable="true" android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/emoji_art" android:textSize="13sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/cat_artisanat" android:textColor="#7FA68A" android:textSize="11sp" android:fontFamily="@font/poppins_regular"/>
            </LinearLayout>
        </LinearLayout>
    </HorizontalScrollView>

    <LinearLayout
        android:id="@+id/sortRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp">

        <TextView
            android:id="@+id/tvAdCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/ad_count_placeholder"
            android:textColor="#7FA68A"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_regular"/>

        <TextView
            android:id="@+id/tvSort"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sort_recent"
            android:textColor="#2ECC71"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_regular"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>


    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAds"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp"
        android:clipToPadding="false"
        android:paddingBottom="80dp"/>

</LinearLayout>