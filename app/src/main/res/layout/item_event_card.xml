<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="140dp"
    android:layout_marginHorizontal="14dp"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_event_card"
    android:clickable="true"
    android:focusable="true"
    android:foreground="@drawable/ripple_green_rounded"
    android:elevation="2dp">

   <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

       <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#1E3D2A">

           <TextView
               android:id="@+id/tvEventImageEmoji"
               android:layout_width="match_parent"
               android:layout_height="match_parent"
               android:layout_gravity="center"
               android:gravity="center"
               android:textSize="52sp"/>
        </FrameLayout>


        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_event_image_fade"/>
    </FrameLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="12dp"
        android:paddingBottom="10dp">

        <!-- Emoji + Title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvEventEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:id="@+id/tvEventTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:fontFamily="@font/poppins_bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:shadowColor="#AA000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="4"/>
        </LinearLayout>

        <!-- Date -->
        <TextView
            android:id="@+id/tvEventDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#EEFFFFFF"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_regular"
            android:layout_marginTop="4dp"
            android:shadowColor="#AA000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="3"/>

        <!-- Location -->
        <TextView
            android:id="@+id/tvEventLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#3CBBDE"
            android:textSize="10sp"
            android:fontFamily="@font/poppins_light"
            android:layout_marginTop="2dp"/>

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <!-- Bottom: interested count + button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvEventInterested"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#99FFFFFF"
                android:textSize="9sp"
                android:fontFamily="@font/poppins_regular"/>

            <TextView
                android:id="@+id/btnInterested"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:gravity="center"
                android:paddingHorizontal="10dp"
                android:textColor="#FFFFFF"
                android:textSize="8sp"
                android:fontFamily="@font/poppins_bold"
                android:background="@drawable/bg_interested_btn"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>
    </LinearLayout>

</FrameLayout>