<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <View
        android:id="@+id/statusBarSpacer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="#132D1F"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="#132D1F">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_back"
            android:contentDescription="@string/back"
            android:padding="4dp"
            android:clickable="true"
            android:focusable="true"
            app:tint="#FFFFFF"/>

        <TextView
            android:id="@+id/tvScreenTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/post_ad_title"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:fontFamily="@font/poppins_bold"
            android:gravity="center"/>

        <View
            android:layout_width="32dp"
            android:layout_height="32dp"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1AFFFFFF"/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- Photos Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/add_photos"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:fontFamily="@font/poppins_bold"
                android:layout_marginStart="25dp"
                android:layout_marginTop="16dp"/>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:scrollbars="none"
                android:paddingHorizontal="24dp"
                android:clipToPadding="false">

                <LinearLayout
                    android:id="@+id/photoContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/btnAddPhoto"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:background="@drawable/bg_photo_add"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginEnd="8dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_add"
                            android:contentDescription="@string/add_photos"
                            app:tint="#7FA68A"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/add_photo_label"
                            android:textColor="#7FA68A"
                            android:textSize="9sp"
                            android:fontFamily="@font/poppins_regular"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ad_field_title"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:fontFamily="@font/poppins_bold"
                android:layout_marginStart="25dp"
                android:layout_marginTop="20dp"/>

            <EditText
                android:id="@+id/etTitle"
                android:layout_width="280dp"
                android:layout_height="40dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_post"
                android:hint="@string/hint_title"
                android:textColor="#FFFFFF"
                android:textColorHint="#4DFFFFFF"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular"
                android:paddingHorizontal="12dp"
                android:inputType="text"
                android:maxLines="1"/>

            <!-- Category -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ad_field_category"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:fontFamily="@font/poppins_bold"
                android:layout_marginStart="25dp"
                android:layout_marginTop="16dp"/>

            <LinearLayout
                android:id="@+id/spinnerCategory"
                android:layout_width="280dp"
                android:layout_height="40dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp"
                android:background="@drawable/bg_spinner_post"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tvCategory"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/hint_category"
                    android:textColor="#4DFFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_regular"/>

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_chevron_down"
                    android:contentDescription="@string/ad_field_category"
                    app:tint="#7FA68A"/>
            </LinearLayout>

            <!-- Price -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ad_field_price"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:fontFamily="@font/poppins_bold"
                android:layout_marginStart="25dp"
                android:layout_marginTop="16dp"/>

            <FrameLayout
                android:layout_width="280dp"
                android:layout_height="40dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp">

                <EditText
                    android:id="@+id/etPrice"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_input_post"
                    android:hint="@string/hint_price"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#4DFFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_regular"
                    android:paddingHorizontal="12dp"
                    android:paddingEnd="48dp"
                    android:paddingStart="7dp"
                    android:inputType="numberDecimal"
                    android:maxLines="1"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical|end"
                    android:layout_marginEnd="12dp"
                    android:text="@string/currency_mad"
                    android:textColor="#4DFFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_regular"/>
            </FrameLayout>

            <!-- City -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ad_field_city"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:fontFamily="@font/poppins_bold"
                android:layout_marginStart="25dp"
                android:layout_marginTop="16dp"/>

            <LinearLayout
                android:id="@+id/spinnerCity"
                android:layout_width="280dp"
                android:layout_height="40dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp"
                android:background="@drawable/bg_spinner_post"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tvCity"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/hint_city"
                    android:textColor="#4DFFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_regular"/>

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_chevron_down"
                    android:contentDescription="@string/ad_field_city"
                    app:tint="#7FA68A"/>
            </LinearLayout>

            <!-- Description -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ad_field_description"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:fontFamily="@font/poppins_bold"
                android:layout_marginStart="25dp"
                android:layout_marginTop="16dp"/>

            <FrameLayout
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp">

                <EditText
                    android:id="@+id/etDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="80dp"
                    android:background="@drawable/bg_input_post"
                    android:hint="@string/hint_description"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#4DFFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_regular"
                    android:paddingHorizontal="12dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="24dp"
                    android:inputType="textMultiLine"
                    android:gravity="top"
                    android:maxLength="500"/>

                <TextView
                    android:id="@+id/tvCharCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="8dp"
                    android:text="@string/char_count_initial"
                    android:textColor="#4DFFFFFF"
                    android:textSize="10sp"
                    android:fontFamily="@font/poppins_regular"/>
            </FrameLayout>

            <!-- Duration -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ad_field_duration"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:fontFamily="@font/poppins_bold"
                android:layout_marginStart="25dp"
                android:layout_marginTop="16dp"/>

            <LinearLayout
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <EditText
                    android:id="@+id/etDuration"
                    android:layout_width="100dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_input_post"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#4DFFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_regular"
                    android:paddingHorizontal="12dp"
                    android:inputType="number"
                    android:hint="@string/hint_duration_default"
                    android:maxLines="1"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/duration_days_label"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:fontFamily="@font/poppins_regular"
                    android:layout_marginStart="12dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvExpiryDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#7FA68A"
                android:textSize="10sp"
                android:fontFamily="@font/poppins_light"
                android:layout_marginStart="40dp"
                android:layout_marginTop="6dp"/>

            <!-- Publish Button -->
            <LinearLayout
                android:id="@+id/btnPublish"
                android:layout_width="150dp"
                android:layout_height="42dp"
                android:layout_gravity="end"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:background="@drawable/bg_button_green"
                android:clickable="true"
                android:focusable="true"
                android:foreground="@drawable/ripple_green_rounded"
                android:elevation="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_publish"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:fontFamily="@font/poppins_bold"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>