<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <LinearLayout
        android:id="@+id/messagesTopBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#132D1F">

        <View
            android:id="@+id/statusBarSpacer"
            android:layout_width="match_parent"
            android:layout_height="0dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingHorizontal="16dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/nav_messages"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:fontFamily="@font/poppins_semibold"/>
        </LinearLayout>
    </LinearLayout>

    <!-- SEARCH BAR -->
    <LinearLayout
        android:id="@+id/messagesSearchBar"
        android:layout_width="match_parent"
        android:layout_height="37dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:background="@drawable/bg_search"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Rechercher des discussions..."
            android:textColor="#4DFFFFFF"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_regular"/>

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_search"
            android:contentDescription="@string/app_name"
            app:tint="#7FA68A"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1E3D2A"
        android:layout_marginTop="10dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="RÉCENTS"
        android:textColor="#7FA68A"
        android:textSize="11sp"
        android:fontFamily="@font/poppins_medium"
        android:letterSpacing="0.05"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvEmptyChats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💬 Aucune conversation\nCommencez à discuter depuis une annonce!"
                android:textColor="#7FA68A"
                android:textSize="14sp"
                android:fontFamily="@font/poppins_regular"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="gone"/>

            <LinearLayout
                android:id="@+id/dynamicChatList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>