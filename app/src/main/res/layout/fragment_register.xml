<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="40dp"
        android:gravity="center_horizontal">

        <FrameLayout
            android:id="@+id/cityContainer"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_surface">

            <TextView
                android:id="@+id/tvCitySelector"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="Choisir votre ville"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"/>

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="12dp"
                android:src="@android:drawable/arrow_down_float"
                android:contentDescription="@string/app_name"
                app:tint="#FFFFFF"/>

        </FrameLayout>

        <EditText
            android:id="@+id/etNom"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginBottom="12dp"
            android:hint="Nom complet"
            android:inputType="textPersonName"
            android:textColor="#FFFFFF"
            android:textColorHint="#4DFFFFFF"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_regular"
            android:paddingHorizontal="16dp"
            android:background="@drawable/bg_input"
            android:singleLine="true"/>

        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginBottom="12dp"
            android:hint="Email"
            android:inputType="textEmailAddress"
            android:textColor="#FFFFFF"
            android:textColorHint="#4DFFFFFF"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_regular"
            android:paddingHorizontal="16dp"
            android:background="@drawable/bg_input"
            android:singleLine="true"/>

        <EditText
            android:id="@+id/etPhone"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginBottom="12dp"
            android:hint="Téléphone"
            android:inputType="phone"
            android:textColor="#FFFFFF"
            android:textColorHint="#4DFFFFFF"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_regular"
            android:paddingHorizontal="16dp"
            android:background="@drawable/bg_input"
            android:singleLine="true"/>

        <!-- Replace etPassword with this: -->
        <FrameLayout
            android:id="@+id/passwordContainer"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginBottom="12dp">

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="@string/mot_de_passe"
                android:inputType="textPassword"
                android:textColor="#FFFFFF"
                android:textColorHint="#4DFFFFFF"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular"
                android:paddingHorizontal="16dp"
                android:paddingEnd="44dp"
                android:background="@drawable/bg_input"
                android:singleLine="true"/>

            <ImageView
                android:id="@+id/ivTogglePassword"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center_vertical|end"
                android:padding="6dp"
                android:src="@drawable/ic_eye_closed"
                android:contentDescription="@string/app_name"
                app:tint="#7FA68A"/>

        </FrameLayout>


        <FrameLayout
            android:id="@+id/confirmPasswordContainer"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginBottom="20dp">

            <EditText
                android:id="@+id/etConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="@string/confirmer_mot_de_passe"
                android:inputType="textPassword"
                android:textColor="#FFFFFF"
                android:textColorHint="#4DFFFFFF"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular"
                android:paddingHorizontal="16dp"
                android:paddingEnd="44dp"
                android:background="@drawable/bg_input"
                android:singleLine="true"/>

            <ImageView
                android:id="@+id/ivToggleConfirmPassword"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center_vertical|end"
                android:padding="6dp"
                android:src="@drawable/ic_eye_closed"
                android:contentDescription="@string/app_name"
                app:tint="#7FA68A"/>

        </FrameLayout>

        <TextView
            android:id="@+id/btnRegister"
            android:layout_width="141dp"
            android:layout_height="42dp"
            android:text="S'inscrire"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:fontFamily="@font/poppins_bold"
            android:gravity="center"
            android:shadowColor="#40000000"
            android:shadowDx="7"
            android:shadowDy="7"
            android:shadowRadius="7"
            android:background="@drawable/bg_btn_green"/>

    </LinearLayout>
</ScrollView>