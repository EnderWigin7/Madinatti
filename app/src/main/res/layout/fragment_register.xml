<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="40dp"
        android:paddingTop="24dp"
        android:paddingBottom="48dp"
        android:gravity="center_horizontal"
        android:layout_gravity="center_vertical">

        <FrameLayout
            android:id="@+id/cityContainer"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_surface">
            <TextView
                android:id="@+id/tvCitySelector"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="@string/choisir_ville"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"/>
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="12dp"
                android:src="@android:drawable/arrow_down_float"
                android:contentDescription="@string/app_name"
                app:tint="#FFFFFF"/>
        </FrameLayout>

        <EditText
            android:id="@+id/etNom"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginBottom="12dp"
            android:hint="@string/nom_complet"
            android:inputType="textPersonName"
            android:textColor="#FFFFFF"
            android:textColorHint="#4DFFFFFF"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_regular"
            android:paddingHorizontal="16dp"
            android:background="@drawable/bg_input"
            android:singleLine="true"/>

        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginBottom="12dp"
            android:hint="@string/email"
            android:inputType="textEmailAddress"
            android:textColor="#FFFFFF"
            android:textColorHint="#4DFFFFFF"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_regular"
            android:paddingHorizontal="16dp"
            android:background="@drawable/bg_input"
            android:singleLine="true"/>

        <EditText
            android:id="@+id/etPhone"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginBottom="12dp"
            android:hint="@string/telephone"
            android:inputType="phone"
            android:textColor="#FFFFFF"
            android:textColorHint="#4DFFFFFF"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_regular"
            android:paddingHorizontal="16dp"
            android:background="@drawable/bg_input"
            android:singleLine="true"/>

        <!-- Password with eye icon -->
        <FrameLayout
            android:id="@+id/passwordContainer"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginBottom="12dp">
            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="@string/mot_de_passe"
                android:inputType="textPassword"
                android:textColor="#FFFFFF"
                android:textColorHint="#4DFFFFFF"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular"
                android:paddingHorizontal="16dp"
                android:paddingEnd="44dp"
                android:background="@drawable/bg_input"
                android:singleLine="true"/>
            <ImageView
                android:id="@+id/ivTogglePassword"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center_vertical|end"
                android:padding="6dp"
                android:src="@drawable/ic_eye_closed"
                android:contentDescription="@string/app_name"
                app:tint="#7FA68A"/>
        </FrameLayout>

        <!-- Confirm password with eye icon -->
        <FrameLayout
            android:id="@+id/confirmPasswordContainer"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginBottom="0dp">
            <EditText
                android:id="@+id/etConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="@string/confirmer_mot_de_passe"
                android:inputType="textPassword"
                android:textColor="#FFFFFF"
                android:textColorHint="#4DFFFFFF"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular"
                android:paddingHorizontal="16dp"
                android:paddingEnd="44dp"
                android:background="@drawable/bg_input"
                android:singleLine="true"/>
            <ImageView
                android:id="@+id/ivToggleConfirmPassword"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center_vertical|end"
                android:padding="6dp"
                android:src="@drawable/ic_eye_closed"
                android:contentDescription="@string/app_name"
                app:tint="#7FA68A"/>
        </FrameLayout>

    </LinearLayout>
</ScrollView>