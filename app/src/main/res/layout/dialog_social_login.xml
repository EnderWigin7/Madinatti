<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="370dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/bg_dialog_glass">

    <!-- Apple -->
    <LinearLayout
        android:id="@+id/btnApple"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="15dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_social_apple"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginEnd="12dp"
            android:contentDescription="@string/app_name"
            android:scaleType="fitCenter"
            android:src="@drawable/apple_logo" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/continuer_apple"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:gravity="center"
            android:fontFamily="@font/poppins_medium"/>

    </LinearLayout>

    <!-- Facebook -->
    <LinearLayout
        android:id="@+id/btnFacebook"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="15dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_social_facebook"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="12dp"
            android:contentDescription="@string/app_name"
            android:scaleType="fitCenter"
            android:src="@drawable/facebook_logo_square" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/continuer_facebook"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:gravity="center"
            android:fontFamily="@font/poppins_medium"/>

    </LinearLayout>

    <!-- Google -->
    <LinearLayout
        android:id="@+id/btnGoogle"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="15dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_social_google"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/google_g_logo"
            android:contentDescription="@string/app_name"
            android:layout_marginEnd="12dp"
            android:scaleType="fitCenter"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/continuer_google"
            android:textColor="#000000"
            android:textSize="10sp"
            android:gravity="center"
            android:fontFamily="@font/poppins_medium"/>

    </LinearLayout>

    <!-- Phone -->
    <LinearLayout
        android:id="@+id/btnPhone"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="15dp"
        android:background="@drawable/bg_social_phone"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_call"
            android:contentDescription="@string/app_name"
            android:layout_marginEnd="12dp"
            app:tint="#FFFFFF"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/continuer_phone"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:gravity="center"
            android:fontFamily="@font/poppins_medium"/>

    </LinearLayout>

</LinearLayout>