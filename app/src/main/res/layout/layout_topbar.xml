<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/topBar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#132D1F">


    <View
        android:id="@+id/statusBarSpacer"
        android:layout_width="match_parent"
        android:layout_height="0dp"/>


    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="12dp">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_back"
            android:contentDescription="@string/app_name"
            android:padding="6dp"
            android:visibility="gone"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:clickable="true"
            android:focusable="true"
            app:tint="#FFFFFF"/>

        <!-- Logo (shown on home only) -->
        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="65dp"
            android:layout_height="44dp"
            android:src="@drawable/madinatilogopdf"
            android:contentDescription="@string/app_name"
            android:scaleType="fitCenter"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"/>

        <!-- City selector — always centered -->
        <LinearLayout
            android:id="@+id/citySelector"
            android:layout_width="130dp"
            android:layout_height="34dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingHorizontal="10dp"
            android:background="@drawable/bg_city_selector"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/ripple_green"
            android:layout_centerInParent="true">

            <TextView
                android:id="@+id/tvCityName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Marrakech"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_regular"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" ▾"
                android:textColor="#7FA68A"
                android:textSize="15sp"/>

        </LinearLayout>


        <ImageView
            android:id="@+id/ivNotifications"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_bell"
            android:contentDescription="@string/app_name"
            android:padding="6dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/ripple_green"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            app:tint="#FFFFFF"/>

    </RelativeLayout>
</LinearLayout>